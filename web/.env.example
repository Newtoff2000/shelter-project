SANITY_PROJECT_ID=j0v2zcj0
SANITY_DATASET=production

# Resend — get key at resend.com
RESEND_API_KEY=re_...

# Destination email for contact form submissions
CONTACT_EMAIL=shelter@example.com

# Umami analytics (cookieless). Leave blank in local dev so the tracking script
# never loads; set NUXT_PUBLIC_UMAMI_WEBSITE_ID in the Vercel project settings
# for production. Get the Website ID from Umami Cloud → website → Settings.
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
# Optional — only override if self-hosting Umami. Defaults to Umami Cloud.
NUXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
